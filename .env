# ─── P1 additions ─────────────────────────────────────────────────────────────
# IMPORTANT: Do NOT prefix any of these with VITE_ — they are server-side only.
# Exposing them in VITE_ vars would leak secrets to the client browser bundle.

# P1-1 | Get from: Lovable dashboard → Account Settings → API Keys
LOVABLE_API_KEY="REPLACE_WITH_YOUR_LOVABLE_API_KEY"

# P1-2 | Get from: Supabase dashboard → Project Settings → API → service_role key
# WARNING: This key bypasses Row Level Security. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_YOUR_SUPABASE_SERVICE_ROLE_KEY"

# P1-4 | Set to your production domain (no trailing slash) for deployed builds.
# For local dev use: http://localhost:3000
SITE_URL="https://your-production-domain.com"
